# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://tor2mega:tor2mega@localhost:5432/tor2mega

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=7d

# Default Mega File Request URL
MEGA_FILE_REQUEST_URL=https://mega.nz/filerequest/bNDOuR4lSVo

# Download settings
MAX_CONCURRENT_DOWNLOADS=3
MAX_UPLOADS=2
MAX_FILE_SIZE_MB=0
RETRY_COUNT=3
TMP_DIR=./tmp/downloads

# yt-dlp / ffmpeg
YT_DLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg

# Stripe (V3 - optional, for billing)
STRIPE_SECRET_KEY=
