{
  "manifest_version": 3,
  "name": "TOR2MEGA",
  "version": "1.0.0",
  "description": "Send videos directly to Mega from your browser",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "assets/icon.svg",
    "default_title": "TOR2MEGA"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "assets/icon.svg",
    "96": "assets/icon.svg"
  }
}
